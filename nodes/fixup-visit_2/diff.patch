+| `/miner/start` | POST | `{"success": true, ...}` | `{"success": true, "status": "MinerStatus.RUNNING"}` | PASS |
+| `/miner/stop` | POST | `{"success": true, ...}` | `{"success": true, "status": "MinerStatus.STOPPED"}` | PASS |
