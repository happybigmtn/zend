+            self.assertEqual(status['status'], 'running')
+            self.assertEqual(status['mode'], 'balanced')
+            self.assertEqual(status['hashrate_hs'], 50000)
+            self.assertEqual(status['observed_by'], 'hermes-001')
+            self.assertIn('observed_at', status)
