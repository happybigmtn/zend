+                self._send_json(200 if result["success"] else 400, result)
+            elif self.path == '/miner/set_mode':
+                mode = data.get('mode')
+                if not mode:
+                    self._send_json(400, {"error": "missing_mode"})
+                    return
+                result = miner.set_mode(mode)
+                self._send_json(200 if result["success"] else 400, result)
         else:
             self._send_json(404, {"error": "not_found"})
 
