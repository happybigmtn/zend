+        )
+        
+        # Add control_receipt
+        spine.append_control_receipt(
+            "start",
+            None,
+            "accepted",
+            principal.id
+        )
+        
+        # Add user_message (should be filtered)
+        spine.append_event(
+            spine.EventKind.USER_MESSAGE,
+            principal.id,
+            {
