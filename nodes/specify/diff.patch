+    def test_hermes_capabilities_defined(self):
+        self.assertEqual(HERMES_CAPABILITIES, ["observe", "summarize"])
+
+    def test_hermes_readable_events_defined(self):
+        expected = {EventKind.HERMES_SUMMARY, EventKind.MINER_ALERT,
