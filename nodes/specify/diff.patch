+    # Test connection with valid token
+    try:
+        conn = connect(token)
+        print(f"Connection established: {conn.hermes_id}")
+        print(f"Capabilities: {conn.capabilities}")
+    except ValueError as e:
+        print(f"Connection failed: {e}")
