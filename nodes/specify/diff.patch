+    suite = loader.loadTestsFromTestCase(TestHermesAdapter)
+    runner = unittest.TextTestRunner(verbosity=2)
+    result = runner.run(suite)
+    return result.wasSuccessful(), result.testsRun, len(result.failures), len(result.errors)
