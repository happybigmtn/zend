 stop_daemon() {
+    # Kill any process holding our port (handles stale daemons from other runs)
+    if command -v fuser &>/dev/null; then
+        fuser -k "$BIND_PORT/tcp" 2>/dev/null || true
+    fi
+
     if [ -f "$PID_FILE" ]; then
