+process_is_running() {
+    local pid="$1"
+    local status=""
+
+    if ! kill -0 "$pid" 2>/dev/null; then
+        return 1
+    fi
+
+    status="$(ps -o stat= -p "$pid" 2>/dev/null | tr -d '[:space:]')"
+    if [[ -z "$status" || "$status" == Z* ]]; then
+        return 1
+    fi
+
+    return 0
