digraph DocumentationAndOnboarding {
    graph [
        goal="Documentation & Onboarding\n\nBootstrap the first honest reviewed slice for this frontier.\n\nInputs:\n- `README.md`\n- `SPEC.md`\n- `SPECS.md`\n- `PLANS.md`\n- `DESIGN.md`\n- `genesis/plans/001-master-plan.md`\n\nCurrent frontier tasks:\n- Rewrite README.md with quickstart and architecture overview\n- Create docs/contributor-guide.md with dev setup instructions\n- Create docs/operator-quickstart.md for home hardware deployment\n- Create docs/api-reference.md with all endpoints documented\n- Create docs/architecture.md with system diagrams and module explanations\n- Verify documentation accuracy by following it on a clean machine\n\nRequired durable artifacts:\n- `outputs/documentation-and-onboarding/spec.md`\n- `outputs/documentation-and-onboarding/review.md`",
        model_stylesheet="
            *       { backend: cli; }
            #review { backend: cli; model: claude-opus-4-6; provider: anthropic; }
            #polish { backend: cli; model: MiniMax-M2.7-highspeed; provider: minimax; }
        "
    ]
    rankdir=LR

    start [shape=Mdiamond, label="Start"]
    exit  [shape=Msquare, label="Exit"]

    specify [label="Specify", prompt="@../../prompts/bootstrap/documentation-and-onboarding/plan.md", reasoning_effort="high"]
    review  [label="Review", prompt="@../../prompts/bootstrap/documentation-and-onboarding/review.md", reasoning_effort="high"]
    polish  [label="Polish", prompt="@../../prompts/bootstrap/documentation-and-onboarding/polish.md", reasoning_effort="medium"]
    verify  [label="Verify", shape=parallelogram, script="test -f ./outputs/documentation-and-onboarding/spec.md && test -f ./outputs/documentation-and-onboarding/review.md", goal_gate=true, max_retries=0]

    start -> specify -> review -> polish -> verify -> exit
}
