digraph HermesAdapterImplementation {
    graph [
        goal="Hermes Adapter Implementation\n\nBootstrap the first honest reviewed slice for this frontier.\n\nInputs:\n- `README.md`\n- `SPEC.md`\n- `SPECS.md`\n- `PLANS.md`\n- `DESIGN.md`\n- `genesis/plans/001-master-plan.md`\n\nCurrent frontier tasks:\n- Create hermes.py adapter module\n- Implement HermesConnection with authority token validation\n- Implement readStatus through adapter\n- Implement appendSummary through adapter\n- Implement event filtering (block user_message events for Hermes)\n- Add Hermes pairing endpoint to daemon\n\nRequired durable artifacts:\n- `outputs/hermes-adapter-implementation/spec.md`\n- `outputs/hermes-adapter-implementation/review.md`",
        model_stylesheet="
            *       { backend: cli; }
            #review { backend: cli; model: claude-opus-4-6; provider: anthropic; }
            #polish { backend: cli; model: MiniMax-M2.7-highspeed; provider: minimax; }
        "
    ]
    rankdir=LR

    start [shape=Mdiamond, label="Start"]
    exit  [shape=Msquare, label="Exit"]

    specify [label="Specify", prompt="@../../prompts/bootstrap/hermes-adapter-implementation/plan.md", reasoning_effort="high"]
    review  [label="Review", prompt="@../../prompts/bootstrap/hermes-adapter-implementation/review.md", reasoning_effort="high"]
    polish  [label="Polish", prompt="@../../prompts/bootstrap/hermes-adapter-implementation/polish.md", reasoning_effort="medium"]
    verify  [label="Verify", shape=parallelogram, script="test -f ./outputs/hermes-adapter-implementation/spec.md && test -f ./outputs/hermes-adapter-implementation/review.md", goal_gate=true, max_retries=0]

    start -> specify -> review -> polish -> verify -> exit
}
