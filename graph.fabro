digraph PrivateControlPlane {
    graph [
        goal="Private Control Plane\n\nBootstrap the first honest reviewed slice for this frontier.\n\nInputs:\n- `README.md`\n- `SPEC.md`\n- `SPECS.md`\n- `PLANS.md`\n- `DESIGN.md`\n- `specs/2026-03-19-zend-product-spec.md`\n\nCurrent frontier tasks:\n- Add the minimal inbox architecture contract for milestone 1, including a shared `PrincipalId` that also owns future inbox access.\n- Add the private event spine contract for milestone 1 and route operations inbox items through it.\n- Implement capability-scoped pairing records with `observe` and `control` permissions.\n\nRequired durable artifacts:\n- `outputs/private-control-plane/control-plane-contract.md`\n- `outputs/private-control-plane/review.md`",
        model_stylesheet="
            *       { backend: cli; }
            #review { backend: api; model: gpt-5.4; provider: openai; }
            #polish { backend: api; model: gpt-5.4; provider: openai; }
        "
    ]
    rankdir=LR

    start [shape=Mdiamond, label="Start"]
    exit  [shape=Msquare, label="Exit"]

    specify [label="Specify", prompt="@../../prompts/bootstrap/private-control-plane/plan.md", reasoning_effort="high"]
    review  [label="Review", prompt="@../../prompts/bootstrap/private-control-plane/review.md", reasoning_effort="high"]
    polish  [label="Polish", prompt="@../../prompts/bootstrap/private-control-plane/polish.md", reasoning_effort="medium"]
    verify  [label="Verify", shape=parallelogram, script="test -f ./outputs/private-control-plane/control-plane-contract.md && test -f ./outputs/private-control-plane/review.md", goal_gate=true, max_retries=0]

    start -> specify -> review -> polish -> verify -> exit
}
