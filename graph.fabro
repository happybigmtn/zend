digraph CarriedForwardBuildCommandCenter {
    graph [
        goal="Carried Forward: Build the Zend Home Command Center\n\nBootstrap the first honest reviewed slice for this frontier.\n\nInputs:\n- `README.md`\n- `SPEC.md`\n- `SPECS.md`\n- `PLANS.md`\n- `DESIGN.md`\n- `genesis/plans/001-master-plan.md`\n\nCurrent frontier tasks:\n- Add automated tests for error scenarios → addressed by genesis plan 004\n- Add tests for trust ceremony, Hermes delegation, event spine routing → addressed by genesis plans 004, 009, 012\n- Document gateway proof transcripts → addressed by genesis plan 008\n- Implement Hermes adapter → addressed by genesis plan 009\n- Implement encrypted operations inbox → addressed by genesis plans 011, 012\n- Restrict to LAN-only with formal verification → partially done (daemon binds localhost), formalized in genesis plan 004 tests\n\nRequired durable artifacts:\n- `outputs/carried-forward-build-command-center/spec.md`\n- `outputs/carried-forward-build-command-center/review.md`",
        model_stylesheet="
            *       { backend: cli; }
            #review { backend: cli; model: claude-opus-4-6; provider: anthropic; }
            #polish { backend: cli; model: MiniMax-M2.7-highspeed; provider: minimax; }
        "
    ]
    rankdir=LR

    start [shape=Mdiamond, label="Start"]
    exit  [shape=Msquare, label="Exit"]

    specify [label="Specify", prompt="@../../prompts/bootstrap/carried-forward-build-command-center/plan.md", reasoning_effort="high"]
    review  [label="Review", prompt="@../../prompts/bootstrap/carried-forward-build-command-center/review.md", reasoning_effort="high"]
    polish  [label="Polish", prompt="@../../prompts/bootstrap/carried-forward-build-command-center/polish.md", reasoning_effort="medium"]
    verify  [label="Verify", shape=parallelogram, script="test -f ./outputs/carried-forward-build-command-center/spec.md && test -f ./outputs/carried-forward-build-command-center/review.md", goal_gate=true, max_retries=0]

    start -> specify -> review -> polish -> verify -> exit
}
