digraph ProofAndValidation {
    graph [
        goal="Proof And Validation\n\nBootstrap the first honest reviewed slice for this frontier.\n\nInputs:\n- `README.md`\n- `SPEC.md`\n- `SPECS.md`\n- `PLANS.md`\n- `DESIGN.md`\n- `specs/2026-03-19-zend-product-spec.md`\n\nCurrent frontier tasks:\n- Prove that the gateway client performs no hashing and only issues control requests to the home miner.\n- Add automated tests for replayed pairing tokens, stale snapshots, controller conflicts, restart recovery, and audit false positives or negatives.\n- Document gateway proof transcripts and exact rerun steps.\n\nRequired durable artifacts:\n- `outputs/proof-and-validation/validation-plan.md`\n- `outputs/proof-and-validation/review.md`",
        model_stylesheet="
            *       { backend: cli; }
            #review { backend: api; model: gpt-5.4; provider: openai; }
            #polish { backend: api; model: gpt-5.4; provider: openai; }
        "
    ]
    rankdir=LR

    start [shape=Mdiamond, label="Start"]
    exit  [shape=Msquare, label="Exit"]

    specify [label="Specify", prompt="@../../prompts/bootstrap/proof-and-validation/plan.md", reasoning_effort="high"]
    review  [label="Review", prompt="@../../prompts/bootstrap/proof-and-validation/review.md", reasoning_effort="high"]
    polish  [label="Polish", prompt="@../../prompts/bootstrap/proof-and-validation/polish.md", reasoning_effort="medium"]
    verify  [label="Verify", shape=parallelogram, script="test -f ./outputs/proof-and-validation/validation-plan.md && test -f ./outputs/proof-and-validation/review.md", goal_gate=true, max_retries=0]

    start -> specify -> review -> polish -> verify -> exit
}
