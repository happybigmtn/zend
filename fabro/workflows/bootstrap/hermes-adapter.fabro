digraph HermesAdapter {
    graph [
        goal="Hermes Adapter\n\nBootstrap the first honest reviewed slice for this frontier.\n\nInputs:\n- `README.md`\n- `SPEC.md`\n- `SPECS.md`\n- `PLANS.md`\n- `DESIGN.md`\n- `specs/2026-03-19-zend-product-spec.md`\n\nCurrent frontier tasks:\n- Add a Zend-native gateway contract and a Hermes adapter that can connect to it using delegated authority.\n- Add the encrypted operations inbox and route pairing approvals, control receipts, alerts, and Hermes summaries into it.\n- Add tests for trust-ceremony state, Hermes delegation boundaries, event spine routing, inbox receipt behavior, and accessibility-sensitive states.\n\nRequired durable artifacts:\n- `outputs/hermes-adapter/agent-adapter.md`\n- `outputs/hermes-adapter/review.md`",
        model_stylesheet="
            *       { backend: cli; }
            #review { backend: api; model: gpt-5.4; provider: openai; }
            #polish { backend: api; model: gpt-5.4; provider: openai; }
        "
    ]
    rankdir=LR

    start [shape=Mdiamond, label="Start"]
    exit  [shape=Msquare, label="Exit"]

    specify [label="Specify", prompt="@../../prompts/bootstrap/hermes-adapter/plan.md", reasoning_effort="high"]
    review  [label="Review", prompt="@../../prompts/bootstrap/hermes-adapter/review.md", reasoning_effort="high"]
    polish  [label="Polish", prompt="@../../prompts/bootstrap/hermes-adapter/polish.md", reasoning_effort="medium"]
    verify  [label="Verify", shape=parallelogram, script="test -f ./outputs/hermes-adapter/agent-adapter.md && test -f ./outputs/hermes-adapter/review.md", goal_gate=true, max_retries=0]

    start -> specify -> review -> polish -> verify -> exit
}
