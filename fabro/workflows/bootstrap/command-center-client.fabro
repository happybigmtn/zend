digraph CommandCenterClient {
    graph [
        goal="Command Center Client\n\nBootstrap the first honest reviewed slice for this frontier.\n\nInputs:\n- `README.md`\n- `SPEC.md`\n- `SPECS.md`\n- `PLANS.md`\n- `DESIGN.md`\n- `specs/2026-03-19-zend-product-spec.md`\n\nCurrent frontier tasks:\n- Add `docs/designs/2026-03-19-zend-home-command-center.md` as the repo design doc for the expanded vertical slice.\n- Implement a thin mobile-shaped gateway client that pairs with the home miner, reads live miner state, and surfaces a named Zend Home onboarding flow.\n\nRequired durable artifacts:\n- `outputs/command-center-client/client-surface.md`\n- `outputs/command-center-client/review.md`",
        model_stylesheet="
            *       { backend: cli; }
            #review { backend: api; model: gpt-5.4; provider: openai; }
            #polish { backend: api; model: gpt-5.4; provider: openai; }
        "
    ]
    rankdir=LR

    start [shape=Mdiamond, label="Start"]
    exit  [shape=Msquare, label="Exit"]

    specify [label="Specify", prompt="@../../prompts/bootstrap/command-center-client/plan.md", reasoning_effort="high"]
    review  [label="Review", prompt="@../../prompts/bootstrap/command-center-client/review.md", reasoning_effort="high"]
    polish  [label="Polish", prompt="@../../prompts/bootstrap/command-center-client/polish.md", reasoning_effort="medium"]
    verify  [label="Verify", shape=parallelogram, script="test -f ./outputs/command-center-client/client-surface.md && test -f ./outputs/command-center-client/review.md", goal_gate=true, max_retries=0]

    start -> specify -> review -> polish -> verify -> exit
}
